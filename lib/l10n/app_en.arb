  "guideAndroidLabel": "Android",
  "@guideAndroidLabel": { "description": "Platform name used in the Android setup guide." },
  "guideAndroidIntro": "Cairn reads from Android Health Connect — it never talks to your watch or band directly. Your tracking apps write data into Health Connect, and Cairn reads it from there.",
  "@guideAndroidIntro": { "description": "Android guide: one-paragraph overview." },
  "guideAndroidStep1Title": "1. Make sure Health Connect is available",
  "@guideAndroidStep1Title": { "description": "Android guide step 1 title." },
  "guideAndroidStep1Body": "On Android 14 and newer it is built into Settings. On older versions, install \"Health Connect\" from the Play Store.",
  "@guideAndroidStep1Body": { "description": "Android guide step 1 body." },
  "guideAndroidStep2Title": "2. Use an app that records your data",
  "@guideAndroidStep2Title": { "description": "Android guide step 2 title." },
  "guideAndroidStep2Body": "Use a health or fitness app that writes to Health Connect — for example Samsung Health, Fitbit, or Garmin Connect (or the fitness app that came with your phone). Cairn reads whatever they store.",
  "@guideAndroidStep2Body": { "description": "Android guide step 2 body." },
  "guideAndroidStep3Title": "3. Pair your wearable in its own app",
  "@guideAndroidStep3Title": { "description": "Android guide step 3 title." },
  "guideAndroidStep3Body": "Pair your watch or band in its vendor app (Samsung Health, Fitbit, Garmin Connect, …). Health Connect does not run on the watch, so data flows watch → vendor app → Health Connect; expect some delay set by the vendor.",
  "@guideAndroidStep3Body": { "description": "Android guide step 3 body." },
  "guideAndroidStep4Title": "4. Link that app to Health Connect",
  "@guideAndroidStep4Title": { "description": "Android guide step 4 title." },
  "guideAndroidStep4Body": "In the vendor/tracking app, turn on the Health Connect integration and let it WRITE the types you want: steps, heart rate, sleep, weight and exercise. Samsung Health also needs its \"process health & wellness data\" consent — a phone restart may be required before data appears.",
  "@guideAndroidStep4Body": { "description": "Android guide step 4 body." },
  "guideAndroidStep5Title": "5. Let Cairn read",
  "@guideAndroidStep5Title": { "description": "Android guide step 5 title." },
  "guideAndroidStep5Body": "Open Cairn and tap Refresh. Grant the Health Connect read permissions Cairn asks for (heart rate, steps, sleep, weight, exercise, plus distance and calories). Cairn only ever reads — it never writes to your health store.",
  "@guideAndroidStep5Body": { "description": "Android guide step 5 body." },
  "guideAndroidNote": "Cairn can only see what your apps actually write to Health Connect, so enable every relevant sub-category in each app. Permissions can be revoked at any time in Health Connect.",
  "@guideAndroidNote": { "description": "Android guide closing caveat." },

  "guideIosLabel": "iPhone",
  "@guideIosLabel": { "description": "Platform name used in the iOS setup guide." },
  "guideIosIntro": "Cairn reads from Apple Health, which is built into iOS. Your data must be in Apple Health first; Cairn reads it from there and never writes back.",
  "@guideIosIntro": { "description": "iOS guide: one-paragraph overview." },
  "guideIosStep1Title": "1. Apple Health is already installed",
  "@guideIosStep1Title": { "description": "iOS guide step 1 title." },
  "guideIosStep1Body": "There is nothing to install — the Health app is part of iOS and the iPhone records steps and walking data automatically.",
  "@guideIosStep1Body": { "description": "iOS guide step 1 body." },
  "guideIosStep2Title": "2. Get richer data into Apple Health",
  "@guideIosStep2Title": { "description": "iOS guide step 2 title." },
  "guideIosStep2Body": "For heart rate and sleep, pair an Apple Watch or your wearable, and use its companion app. Apple Watch writes to Apple Health automatically.",
  "@guideIosStep2Body": { "description": "iOS guide step 2 body." },
  "guideIosStep3Title": "3. Allow your apps to write to Apple Health",
  "@guideIosStep3Title": { "description": "iOS guide step 3 title." },
  "guideIosStep3Body": "For a third-party band/app, open its Apple Health permissions and allow it to write the types you want (heart rate, sleep, weight, workouts).",
  "@guideIosStep3Body": { "description": "iOS guide step 3 body." },
  "guideIosStep4Title": "4. Let Cairn read",
  "@guideIosStep4Title": { "description": "iOS guide step 4 title." },
  "guideIosStep4Body": "Open Cairn and tap Refresh. In the Apple Health sheet, allow Cairn to read heart rate, steps, sleep, weight and workouts. Cairn only ever reads.",
  "@guideIosStep4Body": { "description": "iOS guide step 4 body." },
  "guideIosNote": "iOS hides whether a read permission was granted, so if a metric stays empty, re-check that you allowed it and that the data actually exists in Apple Health.",
  "@guideIosNote": { "description": "iOS guide closing caveat." }
}
